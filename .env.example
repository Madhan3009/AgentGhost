# Ghost Requirement Agent — Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# AI / LLM Configuration
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# Database Configuration (PostgreSQL + pgvector)
# ============================================================
DATABASE_URL=postgresql://ghost:ghostpassword@localhost:5433/ghost_poc

# ============================================================
# Message Broker (Redis)
# ============================================================
REDIS_URL=redis://localhost:6380/0

# ============================================================
# Security
# ============================================================
JWT_SECRET=ghost-agent-super-secret-key-change-in-production
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# ============================================================
# Application Settings
# ============================================================
ENV=development
LOG_LEVEL=INFO

# ============================================================
# HashiCorp Vault — Secret Management (Phase 4)
# ============================================================
# Set VAULT_ENABLED=true to resolve secrets from Vault instead of env vars.
# Default: false (all secrets read from env vars — safe for local dev).
VAULT_ENABLED=false

# Vault server address (dev default: http://localhost:8200)
VAULT_ADDR=http://localhost:8200

# Authentication method: "token" (dev/CI) or "kubernetes" (prod K8s)
VAULT_AUTH_METHOD=token

# Static root token for "token" auth method (dev only — never use in production)
VAULT_TOKEN=root

# Kubernetes ServiceAccount role for "kubernetes" auth method (prod)
VAULT_K8S_ROLE=ghost-agent
VAULT_K8S_MOUNT=kubernetes

# KV v2 mount and path where Ghost secrets are stored
# Structure: <VAULT_MOUNT>/data/<VAULT_PATH>/<key>
# Default resolves to: secret/data/ghost/development
VAULT_MOUNT=secret
VAULT_PATH=ghost/development    # Change to ghost/production for prod

# How long (seconds) to cache the Vault secret bundle in-memory (default: 5 min)
VAULT_CACHE_TTL_SECONDS=300
